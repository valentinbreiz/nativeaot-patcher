<Project Sdk="Microsoft.NET.Sdk">
  <Import Project="../../Cosmos.TestingFramework/build/Cosmos.TestingFramework.props" />

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <!--
    QEMU profiles + modifiers this suite opts into. Definitions live in
    tests/profiles.json; the test runner fails fast if any name here isn't
    in that catalog. The loader enumerates every CONFLICT-FREE SUBSET of
    the applicable modifiers, so each added modifier roughly doubles a
    profile's cells (mutually exclusive ones like gicv2/gicv3 don't
    combine, and arch-filtered ones drop out on the wrong arch). For this
    suite that means: x64 = 2 profiles x {bare, acpi-off} = 4 cells;
    arm64 = 2 profiles x {bare, gicv2, gicv3, acpi-off, gicv2+acpi-off,
    gicv3+acpi-off} = 12 cells. Budget CI timeouts accordingly.
  -->
  <ItemGroup>
    <CosmosTestProfile Include="ahci" />
    <CosmosTestProfile Include="nvme" />
    <CosmosTestModifier Include="gicv2" />
    <CosmosTestModifier Include="gicv3" />
    <CosmosTestModifier Include="acpi-off" />
  </ItemGroup>

  <!-- Core kernel packages (From Local Feed) -->
  <ItemGroup>
    <PackageReference Include="Cosmos.Kernel" />
    <PackageReference Include="Cosmos.Kernel.System" />
    <ProjectReference Include="../../Cosmos.TestingFramework/Cosmos.TestingFramework.csproj" />
  </ItemGroup>

  <Import Project="../../Cosmos.TestingFramework/build/Cosmos.TestingFramework.targets" />
</Project>
