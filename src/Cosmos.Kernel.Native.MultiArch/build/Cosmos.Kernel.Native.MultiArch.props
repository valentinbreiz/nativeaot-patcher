<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="15.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ItemGroup>
    <GCCProject Include="$(MSBuildThisFileDirectory)/C/" />
  </ItemGroup>

  <!-- ACPI/LAI shared sources -->
  <ItemGroup>
    <GCCProject Include="$(MSBuildThisFileDirectory)/ACPI/" />
    <GCCProject Include="$(MSBuildThisFileDirectory)/ACPI/lai/core/" />
    <GCCProject Include="$(MSBuildThisFileDirectory)/ACPI/lai/helpers/" />
    <GCCProject Include="$(MSBuildThisFileDirectory)/ACPI/lai/drivers/" />
    <GCCIncludePath Include="$(MSBuildThisFileDirectory)/ACPI/lai/include/" />
    <GCCIncludePath Include="$(MSBuildThisFileDirectory)/ACPI/lai/core/" />
  </ItemGroup>
</Project>
